{
  "version": 11,

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_FIND_ROOT_PATH_MODE_PACKAGE": "BOTH"
      }
    },
    {
      "name": "linux",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/linux",
      "installDir": "${sourceDir}/install/linux"
    },
    {
      "name": "android",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/android",
      "installDir": "${sourceDir}/install/android",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-29",
        "ANDROID_STL": "c++_shared"
      }
    },
    {
      "name": "wasm",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/wasm",
      "installDir": "${sourceDir}/install/wasm",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
    }
  ],

  "buildPresets": [
    {
      "name": "linux",
      "configurePreset": "linux"
    },
    {
      "name": "android",
      "configurePreset": "android"
    },
    {
      "name": "wasm",
      "configurePreset": "wasm"
    }
  ]
}