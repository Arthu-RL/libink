{
  "version": 6,

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/linux"
    },
    {
      "name": "android",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/android",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-29",
        "ANDROID_STL": "c++_static"
      }
    },
    {
      "name": "wasm",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/wasm",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "linux",
      "configurePreset": "linux"
    },
    {
      "name": "android",
      "configurePreset": "android"
    },
    {
      "name": "wasm",
      "configurePreset": "wasm"
    }
  ],

  "installPresets": [
    {
      "name": "linux",
      "configurePreset": "linux",
      "installDir": "${sourceDir}/install/linux"
    },
    {
      "name": "android",
      "configurePreset": "android",
      "installDir": "${sourceDir}/install/android"
    },
    {
      "name": "wasm",
      "configurePreset": "wasm",
      "installDir": "${sourceDir}/install/wasm"
    }
  ]
}